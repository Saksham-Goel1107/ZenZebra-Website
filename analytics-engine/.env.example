# =========================================================================
# ZENZEBRA ANALYTICS ENGINE - ENVIRONMENT VARIABLES
# =========================================================================
# Copy this file to .env and fill in the actual values.

# -------------------------------------------------------------------------
# 1. APPWRITE CONFIGURATION
# -------------------------------------------------------------------------

# WHY: Tells the SDK where your Appwrite server is hosted.
# HOW: Found in Appwrite Console -> Settings -> Overview.
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1

# WHY: Identifies which project the engine should access.
# HOW: Found in Appwrite Console -> Settings -> Project ID.
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_appwrite_project_id_here

# WHY: Server-side API Key with scopes:
#      databases.read, databases.write, storage.read, storage.write, users.read
# HOW: Appwrite Console -> Project Settings -> API Keys -> Create API Key.
APPWRITE_API_KEY=your_appwrite_api_key_here

# -------------------------------------------------------------------------
# 2. DATABASE & STORAGE IDS
# -------------------------------------------------------------------------

# WHY: The database where ZenZebra data is stored.
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_appwrite_database_id_here

# WHY: Collection for Excel-upload analysis results.
APPWRITE_ANALYTICS_COLLECTION_ID=analytics_results

# (Removed) cron_runs collection is optional; raw snapshot IDs are embedded in
# the analytics results document so a separate cron collection is not required.

# WHY: Storage bucket for uploaded Excel files and generated analysis JSON.
NEXT_PUBLIC_APPWRITE_BUCKET_ID=your_appwrite_bucket_id_here

# -------------------------------------------------------------------------
# 3. SECURITY
# -------------------------------------------------------------------------

# WHY: Shared secret — must match ANALYTICS_SECRET_KEY in the Next.js .env.
# HOW: Generate with: openssl rand -hex 32
ANALYTICS_SECRET_KEY=your_analytics_secret_key_here

# -------------------------------------------------------------------------
# 4. GOOGLE SHEETS CRON JOB
# -------------------------------------------------------------------------

# --- Google Service Account credentials ---
# Option A (recommended for Docker): mount service.json into the container.
#   Place your service account JSON file at analytics-engine/service.json
#   (it is in .gitignore — never commit it).
GOOGLE_SERVICE_ACCOUNT_PATH=/app/service.json

# Option B (for cloud/serverless): paste the raw JSON content of service.json
#   as a single-line string.  If this var is set it takes priority over the path.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# --- Spreadsheet IDs (the long ID in the Google Sheets URL) ---
# WHY: The engine fetches Sales, Stock, and optionally Dead Stock from
#      separate Google Sheets using these IDs.
# HOW: Open the spreadsheet; copy the ID from its URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SALES_ID=your_sales_spreadsheet_id_here
GOOGLE_SHEETS_STOCK_ID=your_stock_spreadsheet_id_here
# Optional — if not set, dead stock analysis is skipped in cron runs.
GOOGLE_SHEETS_DEAD_STOCK_ID=your_dead_stock_spreadsheet_id_here

# --- Worksheet (tab) names within each spreadsheet ---
# These default to "Sheet1" — change if your data is on a different tab.
GOOGLE_SHEETS_SALES_RANGE=Sheet1
GOOGLE_SHEETS_STOCK_RANGE=Sheet1
GOOGLE_SHEETS_DEAD_STOCK_RANGE=Sheet1

# --- Cron schedule (standard 5-field cron expression) ---
# Default: daily at 02:00 server time.
# Examples:
#   0 2 * * *    → Every day at 02:00
#   0 */6 * * *  → Every 6 hours
#   30 1 * * 1   → Every Monday at 01:30
CRON_SCHEDULE=0 2 * * *

# Set to "false" to disable the cron job entirely (manual /cron/trigger still works).
CRON_ENABLED=true

# Timezone for the cron schedule (any IANA tz name).
CRON_TIMEZONE=Asia/Kolkata
